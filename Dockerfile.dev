# Development image for the KPC Vite/React app.
# Deps are installed INSIDE the container (Linux/musl) so the Windows/OneDrive
# host node_modules never has to work — the source is bind-mounted at runtime
# while node_modules stays a container-only volume (see docker-compose.yml).
FROM node:22-alpine

WORKDIR /app

# Install dependencies first so this layer is cached across source edits.
COPY package.json package-lock.json ./
RUN npm ci

# App source is bind-mounted at runtime (for hot-module reload), not copied here.
EXPOSE 5173

# --host 0.0.0.0 makes the dev server reachable from outside the container.
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
